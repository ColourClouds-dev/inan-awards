rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && request.auth.token.superAdmin == true;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // True if the caller's token tenantId claim matches the given tenantId.
    function ownsTenantClaim(tenantId) {
      return isAuthenticated() && request.auth.token.tenantId == tenantId;
    }

    // True if the document's tenantId field matches the caller's claim.
    // Falls back to legacy isAdmin() for backward compatibility.
    function ownsTenant(docTenantId) {
      return isAuthenticated() && (
        request.auth.token.tenantId == docTenantId || isAdmin()
      );
    }

    // True if the caller is an 'owner' (displayed as "Admin") of the given tenant.
    // 'owner' is the raw value stored in Firestore/claims.
    function isOwnerOf(tenantId) {
      return isAuthenticated() &&
        request.auth.token.role == 'owner' &&
        request.auth.token.tenantId == tenantId;
    }

    // True if the caller is any member (owner or staff) of the given tenant.
    function isMemberOf(tenantId) {
      return isAuthenticated() && request.auth.token.tenantId == tenantId;
    }

    // ── Tenants ─────────────────────────────────────────────────────────────
    match /tenants/{tenantId} {
      allow read: if isSuperAdmin() || ownsTenantClaim(tenantId);
      allow create, delete: if isSuperAdmin();
      // Owners can update their own tenant (branding, settings).
      // Staff cannot write to the tenant doc at all.
      allow update: if isSuperAdmin() || isOwnerOf(tenantId);
    }

    // ── Tenant admins mapping ───────────────────────────────────────────────
    match /tenant-admins/{uid} {
      // Super admins can read any doc.
      // Owners can read all docs for their tenant — uses token claim for query compatibility.
      // Any user can read their own doc.
      allow read: if isSuperAdmin()
                  || request.auth.uid == uid
                  || (request.auth.token.role == 'owner' && request.auth.token.tenantId != null);

      // Super admins can write anything.
      allow create: if isSuperAdmin() || request.auth.uid == uid;
      allow delete: if isSuperAdmin();

      // Updates:
      // - Super admins: unrestricted.
      // - Owners: can update their own doc without restriction.
      // - Staff: can only update their own doc, and only the notificationEmails field.
      allow update: if isSuperAdmin()
                    || (
                      request.auth.uid == uid &&
                      request.auth.token.role == 'owner'
                    )
                    || (
                      request.auth.uid == uid &&
                      request.auth.token.role == 'staff' &&
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['notificationEmails'])
                    );
    }

    // ── Per-tenant settings ─────────────────────────────────────────────────
    // All tenant members can read settings (staff need locations for the forms UI).
    // Only owners and super admins can write settings.
    match /tenant-settings/{tenantId}/config/{key} {
      allow read: if isSuperAdmin() || isMemberOf(tenantId);
      allow write: if isSuperAdmin() || isOwnerOf(tenantId);
    }

    // ── Tenant invitations ──────────────────────────────────────────────────
    // Readable by any authenticated user (register page validates token without auth).
    // Only the server (admin SDK) writes these — no client write needed.
    match /tenant-invitations/{token} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ── Feedback forms ──────────────────────────────────────────────────────
    // Public can read active forms.
    // Any tenant member can read all forms in their tenant (including inactive).
    match /feedback-forms/{formId} {
      allow read: if resource.data.isActive == true
                  || isSuperAdmin()
                  || ownsTenant(resource.data.tenantId);
      allow create: if isAuthenticated() && ownsTenant(request.resource.data.tenantId);
      allow update, delete: if isSuperAdmin() || ownsTenant(resource.data.tenantId);
    }

    // ── Feedback responses ──────────────────────────────────────────────────
    // Anyone can create (public form submission).
    // Tenant members can read/update/delete responses for their tenant.
    match /feedback-responses/{responseId} {
      allow create: if true;
      allow read: if isSuperAdmin()
                  || ownsTenant(resource.data.tenantId)
                  || (isAuthenticated() && request.auth.token.tenantId != null);
      allow update, delete: if isSuperAdmin() || ownsTenant(resource.data.tenantId);
    }

    // ── Employees ───────────────────────────────────────────────────────────
    match /employees/{employeeId} {
      allow read: if true;
      allow create: if isAuthenticated() && ownsTenant(request.resource.data.tenantId);
      allow update, delete: if isSuperAdmin() || ownsTenant(resource.data.tenantId);
    }

    // ── Legacy collections ──────────────────────────────────────────────────

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() || isSuperAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isSuperAdmin();
    }
  }
}
