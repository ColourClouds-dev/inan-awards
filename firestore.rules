rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && request.auth.token.superAdmin == true;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // True if the caller's token tenantId claim matches the given tenantId.
    function ownsTenantClaim(tenantId) {
      return isAuthenticated() && request.auth.token.tenantId == tenantId;
    }

    // True if the document's tenantId field matches the caller's claim.
    // Falls back to legacy isAdmin() for backward compatibility.
    function ownsTenant(docTenantId) {
      return isAuthenticated() && (
        request.auth.token.tenantId == docTenantId || isAdmin()
      );
    }

    // True if the caller is an 'owner' (displayed as "Admin") of the given tenant.
    // 'owner' is the raw value stored in Firestore/claims.
    function isOwnerOf(tenantId) {
      return isAuthenticated() &&
        request.auth.token.role == 'owner' &&
        request.auth.token.tenantId == tenantId;
    }

    // True if the caller is any member (owner or staff) of the given tenant.
    function isMemberOf(tenantId) {
      return isAuthenticated() && request.auth.token.tenantId == tenantId;
    }

    // True if the caller is a staff member of the given tenant.
    function isStaffOf(tenantId) {
      return isAuthenticated() &&
        request.auth.token.role == 'staff' &&
        request.auth.token.tenantId == tenantId;
    }

    // True if the caller created the document (createdBy field matches their UID).
    function isCreator() {
      return isAuthenticated() && resource.data.createdBy == request.auth.uid;
    }

    // True if the caller is setting themselves as creator on a new document.
    function isSelfCreating() {
      return isAuthenticated() && request.resource.data.createdBy == request.auth.uid;
    }

    // ── Tenants ─────────────────────────────────────────────────────────────
    match /tenants/{tenantId} {
      allow read: if isSuperAdmin() || ownsTenantClaim(tenantId);
      allow create, delete: if isSuperAdmin();
      // Owners can update their own tenant (branding, settings).
      // Staff cannot write to the tenant doc at all.
      allow update: if isSuperAdmin() || isOwnerOf(tenantId);
    }

    // ── Tenant admins mapping ───────────────────────────────────────────────
    match /tenant-admins/{uid} {
      // Super admins can read any doc.
      // Owners can read all docs for their tenant — uses token claim for query compatibility.
      // Any user can read their own doc.
      allow read: if isSuperAdmin()
                  || request.auth.uid == uid
                  || (request.auth.token.role == 'owner' && request.auth.token.tenantId != null);

      // Super admins can write anything.
      allow create: if isSuperAdmin() || request.auth.uid == uid;
      allow delete: if isSuperAdmin();

      // Updates:
      // - Super admins: unrestricted.
      // - Owners: can update their own doc without restriction.
      // - Staff: can only update their own doc, and only the notificationEmails field.
      allow update: if isSuperAdmin()
                    || (
                      request.auth.uid == uid &&
                      request.auth.token.role == 'owner'
                    )
                    || (
                      request.auth.uid == uid &&
                      request.auth.token.role == 'staff' &&
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['notificationEmails'])
                    );
    }

    // ── Per-tenant settings ─────────────────────────────────────────────────
    // All tenant members can read settings (staff need locations for the forms UI).
    // Only owners and super admins can write settings.
    match /tenant-settings/{tenantId}/config/{key} {
      allow read: if isSuperAdmin() || isMemberOf(tenantId);
      allow write: if isSuperAdmin() || isOwnerOf(tenantId);
    }

    // ── Tenant invitations ──────────────────────────────────────────────────
    // Readable by any authenticated user (register page validates token without auth).
    // Only the server (admin SDK) writes these — no client write needed.
    match /tenant-invitations/{token} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ── Feedback forms ──────────────────────────────────────────────────────
    //
    // Access matrix:
    //   Public (unauthenticated) — read active forms only (for the public /feedback/:id page)
    //   Staff                    — read their OWN forms only (createdBy == uid)
    //   Owner (displayed "Admin")— full read/write over all forms in their tenant
    //   Super admin              — unrestricted
    //
    // IMPORTANT: collection queries are validated against the rule WITHOUT access
    // to resource.data, so tenant membership must be derivable from the token
    // claim alone (request.auth.token.tenantId). The createdBy ownership check
    // is enforced by the application query (where createdBy == uid) AND by the
    // rule on individual document reads/writes via isCreator().
    match /feedback-forms/{formId} {
      // Read:
      //   - Public can read any active form (needed for the public feedback page).
      //   - Owners and super admins can read all forms in their tenant.
      //   - Staff: collection query allowed when tenantId matches their claim;
      //     the app always adds where('createdBy','==',uid) so they only get
      //     their own docs. Individual doc reads are further gated by isCreator().
      allow read: if resource.data.isActive == true
                  || isSuperAdmin()
                  || isOwnerOf(resource.data.tenantId)
                  // Staff collection-query branch: uses only token claims so Firestore
                  // can evaluate the rule without resource.data (required for queries).
                  // The app always adds where('createdBy','==',uid) so staff only
                  // receive their own documents; individual doc reads are further
                  // constrained to their own tenant via the token claim.
                  || (isAuthenticated()
                      && request.auth.token.role == 'staff'
                      && request.auth.token.tenantId != null);

      // Create: any tenant member can create a form, but staff MUST set createdBy
      // to their own UID so the ownership checks above work correctly.
      allow create: if isSuperAdmin()
                    || isOwnerOf(request.resource.data.tenantId)
                    || (isStaffOf(request.resource.data.tenantId) && isSelfCreating());

      // Update: owners can edit any form in their tenant; staff only their own.
      allow update: if isSuperAdmin()
                    || isOwnerOf(resource.data.tenantId)
                    || (isStaffOf(resource.data.tenantId) && isCreator());

      // Delete: owners can delete any form; staff only their own.
      allow delete: if isSuperAdmin()
                    || isOwnerOf(resource.data.tenantId)
                    || (isStaffOf(resource.data.tenantId) && isCreator());
    }

    // ── Feedback responses ──────────────────────────────────────────────────
    //
    // Responses are submitted publicly (no auth needed for create).
    // Staff scoping to their own form IDs is enforced at the application layer —
    // getAllResponses() is always called with the staff member's formIds.
    // The rule grants read access to any authenticated tenant member; the app
    // query constrains what is actually fetched.
    //
    // Access matrix:
    //   Public     — create only (form submission)
    //   Staff      — read responses for their tenant (app code scopes to own formIds)
    //   Owner      — read/update/delete all responses in their tenant
    //   Super admin— unrestricted
    match /feedback-responses/{responseId} {
      allow create: if true;

      // Allow public get requests (needed for shareable links to retrieve unguessable UUID docs)
      allow get: if true;

      // Restrict collection-level queries/listings to authenticated tenant members
      allow list: if isSuperAdmin()
                  || (isAuthenticated()
                      && request.auth.token.role == 'owner'
                      && request.auth.token.tenantId == resource.data.tenantId)
                  || (isAuthenticated()
                      && request.auth.token.role == 'staff'
                      && request.auth.token.tenantId == resource.data.tenantId);

      // Only owners and super admins can update or delete responses.
      allow update, delete: if isSuperAdmin()
                             || (isAuthenticated()
                                 && request.auth.token.role == 'owner'
                                 && request.auth.token.tenantId == resource.data.tenantId);
    }

    // ── Employees ───────────────────────────────────────────────────────────
    match /employees/{employeeId} {
      allow read: if true;
      allow create: if isAuthenticated() && ownsTenant(request.resource.data.tenantId);
      allow update, delete: if isSuperAdmin() || ownsTenant(resource.data.tenantId);
    }

    // ── Legacy collections ──────────────────────────────────────────────────

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() || isSuperAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isSuperAdmin();
    }
  }
}
