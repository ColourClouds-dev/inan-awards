rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && request.auth.token.superAdmin == true;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // True if the authenticated user's token claim matches the given tenantId.
    // Used for both document-level and query-level checks.
    function ownsTenantClaim(tenantId) {
      return isAuthenticated() && request.auth.token.tenantId == tenantId;
    }

    // True if the document's tenantId field matches the user's claim.
    // Falls back to legacy isAdmin() for backward compatibility.
    function ownsTenant(docTenantId) {
      return isAuthenticated() && (
        request.auth.token.tenantId == docTenantId || isAdmin()
      );
    }

    // ── Tenants ─────────────────────────────────────────────────────────────
    match /tenants/{tenantId} {
      allow read: if isSuperAdmin() || ownsTenantClaim(tenantId);
      // Super admins can write anything; tenant admins can update their own doc
      // (e.g. branding, settings) but cannot create or delete tenants.
      allow create, delete: if isSuperAdmin();
      allow update: if isSuperAdmin() || ownsTenantClaim(tenantId);
    }

    // ── Tenant admins mapping ───────────────────────────────────────────────
    match /tenant-admins/{uid} {
      allow read: if isSuperAdmin() || request.auth.uid == uid;
      allow write: if isSuperAdmin() || request.auth.uid == uid;
    }

    // ── Per-tenant settings ─────────────────────────────────────────────────
    match /tenant-settings/{tenantId}/config/{key} {
      allow read: if isSuperAdmin() || ownsTenantClaim(tenantId);
      allow write: if isSuperAdmin() || ownsTenantClaim(tenantId);
    }

    // ── Feedback forms ──────────────────────────────────────────────────────
    // Public can read active forms.
    // Tenant admin can read ALL their forms (including inactive) via query.
    match /feedback-forms/{formId} {
      allow read: if resource.data.isActive == true
                  || isSuperAdmin()
                  || ownsTenant(resource.data.tenantId);
      allow create: if isAuthenticated() && ownsTenant(request.resource.data.tenantId);
      allow update, delete: if isSuperAdmin() || ownsTenant(resource.data.tenantId);
    }

    // ── Feedback responses ──────────────────────────────────────────────────
    // Anyone can create (public form submission).
    // Tenant admin can read/update/delete their own responses.
    // The query-level rule allows listing even when the collection is empty
    // by checking the user's token claim directly.
    match /feedback-responses/{responseId} {
      allow create: if true;
      allow read: if isSuperAdmin()
                  || ownsTenant(resource.data.tenantId)
                  || (isAuthenticated() && request.auth.token.tenantId != null);
      allow update, delete: if isSuperAdmin() || ownsTenant(resource.data.tenantId);
    }

    // ── Employees ───────────────────────────────────────────────────────────
    match /employees/{employeeId} {
      allow read: if true;
      allow create: if isAuthenticated() && ownsTenant(request.resource.data.tenantId);
      allow update, delete: if isSuperAdmin() || ownsTenant(resource.data.tenantId);
    }

    // ── Legacy collections ──────────────────────────────────────────────────

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() || isSuperAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isSuperAdmin();
    }
  }
}
